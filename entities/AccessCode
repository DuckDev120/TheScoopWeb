{
  "name": "AccessCode",
  "type": "object",
  "properties": {
    "code_string": {
      "type": "string",
      "description": "The unique access code (e.g. SCOOP-A1B2C3)"
    },
    "is_used": {
      "type": "boolean",
      "default": false,
      "description": "Whether this code has been redeemed"
    },
    "used_by": {
      "type": "string",
      "description": "Identifier of who used the code"
    },
    "used_date": {
      "type": "string",
      "format": "date-time",
      "description": "When the code was used"
    },
    "generated_by": {
      "type": "string",
      "description": "Admin who generated the code"
    }
  },
  "required": [
    "code_string"
  ]
}